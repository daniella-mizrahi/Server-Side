<%- include('../includes/head.ejs') %>

<title>Roomies | הרשמה</title>
<link rel="stylesheet" href="/css/home.css">
<style>
  .auth-page { max-width: 580px; margin: var(--sp-3xl) auto; padding: 0 var(--sp-xl); }
  .auth-card { background: var(--clr-surface); border: 1px solid var(--clr-border); border-radius: var(--radius-xl); padding: var(--sp-2xl); box-shadow: var(--shadow-md); }
  .auth-header { text-align: center; margin-bottom: var(--sp-xl); }
  .auth-title { font-size: var(--fs-2xl); margin-bottom: var(--sp-xs); }
  .auth-subtitle { color: var(--clr-text-muted); }
  .alert { padding: var(--sp-md); border-radius: var(--radius-md); margin-bottom: var(--sp-lg); font-weight: 600; text-align: center; }
  .alert.error { background: rgba(255,82,82,0.12); border: 1px solid var(--clr-error); color: var(--clr-error); }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: var(--sp-lg); }
  .auth-footer { text-align: center; margin-top: var(--sp-lg); font-size: var(--fs-sm); }
  .auth-footer a { color: var(--clr-primary-light); }
  @media(max-width:640px) { .form-row { grid-template-columns: 1fr; } }
</style>
</head>
<body>

<%- include('../includes/menu.ejs') %>

<main class="auth-page">
  <section class="auth-card">
    <div class="auth-header">
      <h1 class="auth-title">הרשמה</h1>
      <p class="auth-subtitle">צרי חשבון חדש ב-Roomies</p>
    </div>

    <% if (typeof formError !== 'undefined' && formError) { %>
      <div class="alert error"><%= formError %></div>
    <% } %>

    <form action="/auth/register" method="POST" novalidate>
      <div class="form-row">
        <div class="form-group">
          <label class="form-label" for="username">שם משתמש <span class="required">*</span></label>
          <input id="username" name="username" type="text" class="form-control" value="<%= typeof values !== 'undefined' ? values.username : '' %>" required>
        </div>
        <div class="form-group">
          <label class="form-label" for="password">סיסמה <span class="required">*</span></label>
          <input id="password" name="password" type="password" class="form-control" required>
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label class="form-label" for="city_preference">עיר מועדפת <span class="required">*</span></label>
          <input id="city_preference" name="city_preference" type="text" class="form-control" value="<%= typeof values !== 'undefined' ? values.city_preference : '' %>" required>
        </div>
        <div class="form-group">
          <label class="form-label" for="budget_range">טווח תקציב <span class="required">*</span></label>
          <select id="budget_range" name="budget_range" class="form-control" required>
            <option value="" disabled selected>בחרי</option>
            <option value="under_2000">עד 2,000 ש"ח</option>
            <option value="2000_3500">2,000 — 3,500 ש"ח</option>
            <option value="3500_5000">3,500 — 5,000 ש"ח</option>
            <option value="above_5000">מעל 5,000 ש"ח</option>
          </select>
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label class="form-label" for="lifestyle_type">סגנון חיים <span class="required">*</span></label>
          <select id="lifestyle_type" name="lifestyle_type" class="form-control" required>
            <option value="" disabled selected>בחרי</option>
            <option value="early_bird">ציפור מוקדמת</option>
            <option value="night_owl">ינשוף לילה</option>
            <option value="homebody">ביתית</option>
            <option value="social_butterfly">חברותית</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label" for="pet_policy">מדיניות חיות <span class="required">*</span></label>
          <select id="pet_policy" name="pet_policy" class="form-control" required>
            <option value="" disabled selected>בחרי</option>
            <option value="has_pet">יש לי חיית מחמד</option>
            <option value="loves_pets">אוהבת חיות</option>
            <option value="no_pets">בלי חיות</option>
            <option value="allergic">אלרגית</option>
          </select>
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label class="form-label" for="smoking_policy">מדיניות עישון <span class="required">*</span></label>
          <select id="smoking_policy" name="smoking_policy" class="form-control" required>
            <option value="" disabled selected>בחרי</option>
            <option value="smoker">מעשנת</option>
            <option value="outdoor_only">רק בחוץ</option>
            <option value="non_smoker">לא מעשנת</option>
            <option value="no_smoking_home">בלי עישון בבית</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label" for="roommate_gender_pref">העדפת שותפ/ה <span class="required">*</span></label>
          <select id="roommate_gender_pref" name="roommate_gender_pref" class="form-control" required>
            <option value="" disabled selected>בחרי</option>
            <option value="female_only">בנות בלבד</option>
            <option value="male_only">בנים בלבד</option>
            <option value="any">לא משנה</option>
          </select>
        </div>
      </div>

      <button type="submit" class="btn btn--primary" style="width:100%; margin-top:var(--sp-lg)">הירשמי</button>

      <div class="auth-footer">
        <p>יש לך חשבון? <a href="/auth/login">התחברי כאן</a></p>
      </div>
    </form>
  </section>
</main>

<footer class="site-footer" role="contentinfo">
  <p>&copy; 2026 Roomies — כל הזכויות שמורות</p>
</footer>

</body>
</html>
